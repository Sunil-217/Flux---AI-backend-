# Copy this file to `.env` and fill in real values.

# ── App mode ── set to "production" to enable strict startup checks
# (refuses to boot with default JWT_SECRET / localhost CORS / missing keys).
APP_ENV=development

# ── NVIDIA NIM API (LLM) — required ──
NVIDIA_API_KEY=your-nvidia-api-key

# ── Tavily (live web search) — optional; web search is disabled if unset ──
TAVILY_API_KEY=your-tavily-api-key

# ── Pollinations.ai (used by /video slash command) — optional ──
# Without this, /video returns a friendly error pointing here.
# Free signup, no credit card: https://enter.pollinations.ai/
POLLINATIONS_API_KEY=your-pollinations-seed-key

# ── Email (SMTP) for OTP — e.g. Brevo. If unset, OTP codes print to the server console. ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login
SMTP_PASS=your-smtp-key
SMTP_FROM=your-verified-sender@example.com

# ── Auth / security ──
# REQUIRED in production: a strong random 32+ character secret.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-long-random-string-here
JWT_EXPIRE_MINUTES=10080
OTP_TTL_MINUTES=10

# ── CORS: comma-separated allowed frontend origins ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database (optional; defaults to local SQLite). For production use Postgres, e.g.:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./flux_ai.db

# ── Fluxway PSP orchestration (optional) ──
# Set all three to drive the Payment Gateways "Add" picker from Fluxway's live
# PSP catalog and onboard a PSP at brand level. Leave unset for local-only mode.
#   FLUXWAY_BASE_URL      — API base incl. prefix, e.g. http://localhost:7111/fluxway/v2
#   FLUXWAY_SECRET_TOKEN  — a brand environment secret (X-SECRET-TOKEN); it is
#                           bound to one brand+environment, so onboarding is
#                           scoped there. Rotate via Fluxway's
#                           PUT /brands/{id}/environments/{eid}/rotate-secret.
#   FLUXWAY_PSP_FLOW_TYPE — the FlowType name whose targets are the PSP catalog.
FLUXWAY_BASE_URL=
FLUXWAY_SECRET_TOKEN=
FLUXWAY_PSP_FLOW_TYPE=PSP
